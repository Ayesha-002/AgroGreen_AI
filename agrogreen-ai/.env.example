# AgroGreen AI — Environment Variables
# Copy this file to .env and fill in your values

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenWeather
OPENWEATHER_API_KEY=your-openweather-api-key-here

# App
APP_HOST=0.0.0.0
APP_PORT=8000
GRADIO_PORT=7860
DEMO_MODE=true  # Set to false when real APIs are configured
